    "deploy": "firebase deploy --only functions:enrichOnPendingJob"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.0",
    "jest": "^30.3.0"
  }
}
